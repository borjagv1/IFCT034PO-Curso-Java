<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package name="miPaquete" extends="struts-default" namespace="/">

        <action name="saludar" class="org.prueba.acciones.Accion">
            <result name="success">/bienvenido.jsp</result>
            <result name="login_failed">/login.jsp</result>
            <result name="account_locked">/cuenta-bloqueada.jsp</result>
            <result name="input">/index.jsp</result>
        </action>

    </package>
</struts>